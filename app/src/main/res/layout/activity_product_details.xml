<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".view.ProductDetailsActivity">

    <ImageView android:layout_width="match_parent"
               android:id="@+id/ivProductImage"
               android:layout_height="@dimen/product_image_ht"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintLeft_toLeftOf="parent"
               app:layout_constraintRight_toRightOf="parent"
               android:src="@mipmap/ic_launcher"/>

    <TextView
            android:id="@+id/tvProductName"
            android:gravity="center_vertical"
            android:textSize="@dimen/default_text_size"
            tools:text="Item Name"
            app:layout_constraintTop_toBottomOf="@+id/ivProductImage"
            android:padding="@dimen/default_margin"
            android:layout_width="match_parent"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvSize"
            android:gravity="center_vertical"
            android:textSize="@dimen/default_text_size"
            android:text="@string/label_size"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvProductName"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintRight_toLeftOf="@+id/tvSizeValue"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvSizeValue"
            app:layout_constraintLeft_toRightOf="@+id/tvSize"
            android:gravity="center_vertical"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintHorizontal_weight="1"
            android:textSize="@dimen/default_text_size"
            tools:text="44"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tvProductName"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvColor"
            android:gravity="center_vertical"
            android:textSize="@dimen/default_text_size"
            android:text="@string/label_color"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSize"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintRight_toLeftOf="@+id/tvColorValue"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvColorValue"
            app:layout_constraintLeft_toRightOf="@+id/tvColor"
            android:gravity="center_vertical"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintHorizontal_weight="1"
            android:textSize="@dimen/default_text_size"
            tools:text="12.8"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tvSize"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvPrice"
            android:gravity="center_vertical"
            android:textSize="@dimen/default_text_size"
            android:text="@string/label_price"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvColor"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintRight_toLeftOf="@+id/tvPriceValue"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvPriceValue"
            app:layout_constraintLeft_toRightOf="@+id/tvPrice"
            android:gravity="center_vertical"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintHorizontal_weight="1"
            android:textSize="@dimen/default_text_size"
            tools:text="12.8"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tvColor"
            android:layout_height="@dimen/default_ht"/>


    <TextView
            android:id="@+id/tvTax"
            android:gravity="center_vertical"
            android:textSize="@dimen/default_text_size"
            android:text="@string/label_tax"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvPrice"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintRight_toLeftOf="@+id/tvTaxValue"
            android:layout_height="@dimen/default_ht"/>

    <TextView
            android:id="@+id/tvTaxValue"
            app:layout_constraintLeft_toRightOf="@+id/tvTax"
            android:gravity="center_vertical"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintHorizontal_weight="1"
            android:textSize="@dimen/default_text_size"
            tools:text="12.8"
            android:padding="@dimen/default_margin"
            android:layout_width="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tvPrice"
            android:layout_height="@dimen/default_ht"/>

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSizeVariants"
            android:layout_width="match_parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTaxValue"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/default_margin"
            android:layout_height="@dimen/default_ht"/>

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvColorVariants"
            android:layout_width="match_parent"
            app:layout_constraintTop_toBottomOf="@+id/rvSizeVariants"
            android:orientation="horizontal"
            android:layout_height="@dimen/default_ht"/>

</androidx.constraintlayout.widget.ConstraintLayout>
